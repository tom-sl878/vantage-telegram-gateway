# Telegram Bot Token (required)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Backend API URL (default: http://localhost:8000)
VANTAGE_API_URL=http://localhost:8000

# LLM Provider: "vllm" or "claude" (default: vllm)
LLM_PROVIDER=vllm

# vLLM Configuration (when LLM_PROVIDER=vllm)
VLLM_URL=http://10.0.8.2:8003/v1/chat/completions
VLLM_MODEL=Qwen/Qwen3-8B

# Claude Configuration (when LLM_PROVIDER=claude)
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Shared model settings
# MODEL_TEMPERATURE=0.7
# MODEL_MAX_TOKENS=2000

# Default project slug (default: demo-project)
DEFAULT_PROJECT_SLUG=demo-project

# Script directories
TASK_SCRIPTS_DIR=/Users/tom/Projects/OSAP/Vantage/scripts/tasks
RFP_SCRIPTS_DIR=/Users/tom/Projects/OSAP/Vantage/scripts/rfp
PROJECT_SCRIPTS_DIR=/Users/tom/Projects/OSAP/Vantage/scripts/projects

# Logging level (default: INFO)
LOG_LEVEL=INFO
